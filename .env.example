PORT=3000

# Administrador: defina estes valores no Render, nunca no GitHub.
ADMIN_EMAIL=seuemail@exemplo.com
ADMIN_PASSWORD=uma_senha_forte_e_unica
AUTH_SECRET=gere_uma_chave_aleatoria_longa

# Mercado Pago (Checkout Pro). Nunca publique o ACCESS_TOKEN no GitHub.
MERCADOPAGO_PUBLIC_KEY=TEST-sua_chave_publica
MERCADOPAGO_ACCESS_TOKEN=TEST-seu_access_token

# URL publica do frontend para onde o cliente volta depois do pagamento.
# Exemplo: https://seu-usuario.github.io/seu-repositorio
MERCADOPAGO_SITE_URL=https://augustonvsilva.github.io/loja-multimarcas

# URL HTTPS publica do backend para receber notificacoes. Exemplo:
# https://sua-api.onrender.com/api/payments/webhook
MERCADOPAGO_WEBHOOK_URL=

# Loja: Rua Jacinto Pereira, 151 - Pan-Americano, Jaragua-SP.
CORREIOS_ORIGIN_CEP=02992130

# Ambiente: production ou homologation.
CORREIOS_ENV=production

# Credenciais geradas no CWS / Meu Correios.
CORREIOS_USERNAME=seu_id_correios
CORREIOS_API_PASSWORD=seu_codigo_de_acesso_api
CORREIOS_CARD_NUMBER=seu_cartao_de_postagem
CORREIOS_CONTRACT_NUMBER=seu_numero_de_contrato
CORREIOS_DR=72

# Medidas padrao da embalagem usada na cotacao.
CORREIOS_DEFAULT_WEIGHT_GRAMS=500
CORREIOS_DEFAULT_LENGTH_CM=20
CORREIOS_DEFAULT_WIDTH_CM=20
CORREIOS_DEFAULT_HEIGHT_CM=10
